# Environment
NODE_ENV=development
PORT=3000
APP_NAME=WazAssist AI

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=your-account-id
# AWS credentials loaded from ~/.aws/credentials
# No need to set AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY here

# Database (Aurora PostgreSQL) i am starting with docker postgreSQL and i will later move to Aurora
#DATABASE_HOST=wazassist-db.cluster-xxx.eu-west-1.rds.amazonaws.com
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=wazassist
#DATABASE_USER=wazassist_admin
DATABASE_USER=postgres
DATABASE_PASSWORD=WazAssist2025Dev!
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10


# Redis (ElastiCache)
REDIS_HOST=wazassist-cache.xxx.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_TLS=true

# AWS Bedrock (LLM) - Use inference profile IDs
BEDROCK_MODEL_ID_8B=us.meta.llama3-1-8b-instruct-v1:0
BEDROCK_MODEL_ID_70B=us.meta.llama3-1-70b-instruct-v1:0
BEDROCK_DEFAULT_MODEL=8B
BEDROCK_MAX_TOKENS=2048
BEDROCK_TEMPERATURE=0.7

# AWS OpenSearch (Vector Store)
OPENSEARCH_ENDPOINT=https://xxx.eu-west-1.aoss.amazonaws.com
OPENSEARCH_INDEX_PRODUCTS=products
OPENSEARCH_INDEX_CONVERSATIONS=conversations

# AWS S3
S3_BUCKET_MEDIA=wazassist-media-prod
S3_BUCKET_INVOICES=wazassist-invoices-prod
S3_BUCKET_TRAINING=wazassist-training-data
S3_REGION=eu-west-1

# AWS SQS
SQS_QUEUE_MESSAGES=https://sqs.eu-west-1.amazonaws.com/xxx/wazassist-messages
SQS_QUEUE_INVOICES=https://sqs.eu-west-1.amazonaws.com/xxx/wazassist-invoices

# AWS SNS
SNS_TOPIC_ORDERS=arn:aws:sns:eu-west-1:xxx:wazassist-orders
SNS_TOPIC_ALERTS=arn:aws:sns:eu-west-1:xxx:wazassist-alerts

# AWS Cognito
COGNITO_USER_POOL_ID=eu-west-1_xxxxx
COGNITO_CLIENT_ID=your-client-id
COGNITO_REGION=eu-west-1

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_VERSION=v18.0
WHATSAPP_API_URL=https://graph.facebook.com
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_APP_SECRET=your-app-secret

# Alternative: 360Dialog
# WHATSAPP_360DIALOG_API_KEY=your-360dialog-api-key
# WHATSAPP_360DIALOG_CLIENT_ID=your-client-id

# Paystack (Nigerian Payment Gateway)
PAYSTACK_PUBLIC_KEY=pk_test_xxxxx
PAYSTACK_SECRET_KEY=sk_test_xxxxx
PAYSTACK_WEBHOOK_SECRET=your-webhook-secret
PAYSTACK_CALLBACK_URL=https://api.wazassist.ai/webhooks/paystack

# Flutterwave (Nigerian Payment Gateway)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxx
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TESTxxxxx
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret
FLUTTERWAVE_CALLBACK_URL=https://api.wazassist.ai/webhooks/flutterwave

# JWT Authentication
# use "openssl rand -hex 64" to generate secret.
JWT_SECRET=07506790c4cf96352558b7031c5de6380fa0d3eb3bac776a9e41cd61e68ddd54ae2d4a3ec675830d072810bfe21cdd93836129ac152a8d78e96f493c0002fdbd
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-refresh-token-secret
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WHATSAPP_MAX=1000

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-for-aes256
ENCRYPTION_ALGORITHM=aes-256-gcm

# AI Configuration
AI_RESPONSE_TIMEOUT_MS=5000
AI_MAX_RETRIES=3
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600
AI_FALLBACK_ENABLED=true
AI_FALLBACK_MESSAGE="Sorry, I'm having trouble right now. A human will help you soon."

# Multilingual Support
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,pidgin,yoruba,igbo,hausa
TRANSLATION_SERVICE=aws-translate

# Business Rules
MAX_MESSAGE_LENGTH=4096
MAX_FILE_SIZE_MB=16
ORDER_TIMEOUT_MINUTES=30
SESSION_TIMEOUT_MINUTES=60
LOW_STOCK_THRESHOLD=10

# Monitoring & Logging
LOG_LEVEL=info
LOG_FORMAT=json
CLOUDWATCH_LOG_GROUP=/aws/ecs/wazassist
CLOUDWATCH_LOG_STREAM=backend
ENABLE_XRAY=true

# Feature Flags
FEATURE_AI_ENABLED=true
FEATURE_VOICE_MESSAGES=false
FEATURE_IMAGE_RECOGNITION=false
FEATURE_MULTI_AGENT=false
FEATURE_ANALYTICS=true

# Email (SES)
SES_REGION=eu-west-1
SES_FROM_EMAIL=noreply@wazassist.ai
SES_FROM_NAME=WazAssist AI

# SMS Backup (Termii - Nigerian SMS Gateway)
TERMII_API_KEY=your-termii-api-key
TERMII_SENDER_ID=WazAssist

# Application URLs
#FRONTEND_URL=https://dashboard.wazassist.ai
#API_URL=https://api.wazassist.ai
#WEBHOOK_BASE_URL=https://api.wazassist.ai/webhooks
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000
WEBHOOK_BASE_URL=http://localhost:3000/webhooks

# Subscription Tiers (Message Limits)
TIER_STARTER_MESSAGE_LIMIT=500
TIER_GROWTH_MESSAGE_LIMIT=2500
TIER_PRO_MESSAGE_LIMIT=10000
TIER_ENTERPRISE_MESSAGE_LIMIT=100000

# Pricing (in Naira)
PRICE_STARTER_MONTHLY=5000
PRICE_GROWTH_MONTHLY=15000
PRICE_PRO_MONTHLY=40000
PRICE_ENTERPRISE_MONTHLY=custom

# Development Only
DEBUG=false
MOCK_WHATSAPP=true
MOCK_PAYMENTS=false
MOCK_AI=false

# OpenAI Fallback (Optional)
USE_OPENAI_FALLBACK=false
OPENAI_API_KEY=
