# Webhook Configuration
# ------------------
WEBHOOK_BASE_URL=https://api.wazassist.com/webhooks

# ------------------
# Rate Limiting
# ------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ------------------
# Logging & Monitoring
# ------------------
LOG_LEVEL=info
LOG_FILE=logs/wazassist-production.log

# CloudWatch Logs (optional)
CLOUDWATCH_LOG_GROUP=/aws/wazassist/production
CLOUDWATCH_LOG_STREAM=api-server

# Sentry for error tracking (optional)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=production

# ------------------
# Email Service (optional)
# ------------------
SMTP_HOST=email-smtp.eu-west-1.amazonaws.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@wazassist.com
SMTP_FROM_NAME=WazAssist AI

# ------------------
# Security
# ------------------
BCRYPT_ROUNDS=12
SESSION_SECRET=hB4itG0YDaNMXjsBC34_7PBgQprgjzar8eLq04jYWVDeqJ6GGmNeuSKdPBrBxwAw48y_u7hLWDOpFf2kowGGQw
CORS_ORIGIN=https://wazassist.com

# ------------------
# Feature Flags
