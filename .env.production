# ==============================================
# WazAssist AI - Production Environment Variables
# ==============================================
# IMPORTANT: Copy this file to .env.production and fill in actual values
# NEVER commit the actual .env.production file to version control

# ------------------
# Application
# ------------------
NODE_ENV=production
PORT=3000
APP_NAME=WazAssist AI
APP_BASE_URL=https://api.wazassist.com
FRONTEND_URL=https://wazassist.com

# ------------------
# Database (PostgreSQL)
# ------------------
DATABASE_HOST=wazassist-prod-db.cs7q4g042mqd.us-east-1.rds.amazonaws.com
DATABASE_PORT=5432
DATABASE_NAME=wazassist_prod
DATABASE_USER=wazassist_user
DATABASE_PASSWORD="WazAssistDb!2026#Prod"
DATABASE_SSL=true
DATABASE_SSL_REJECT_UNAUTHORIZED=false
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ------------------
# Redis (Session & Cache)
# ------------------
REDIS_HOST=master.wazassist-prod-redis.zqj0vn.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD="WazAssistRedis!2026#Prod"
REDIS_TLS=true
REDIS_TLS_REJECT_UNAUTHORIZED=false

# ------------------
