BEDROCK_MAX_TOKENS=1000
BEDROCK_TEMPERATURE=0.7

# ------------------
# OpenAI (Fallback)
# ------------------
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000

# ------------------
# WhatsApp Business API
# ------------------
