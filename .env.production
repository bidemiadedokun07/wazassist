# AWS Bedrock for AI (use inference profile IDs)
BEDROCK_MODEL_ID_8B=us.meta.llama3-1-8b-instruct-v1:0
BEDROCK_MODEL_ID_70B=us.meta.llama3-1-70b-instruct-v1:0
