{
  "name": "wazassist-ai",
  "version": "1.0.0",
  "description": "AI-Powered WhatsApp Business Assistant for Nigerian SMEs",
  "main": "backend/src/index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon backend/src/index.js",
    "start": "node backend/src/index.js",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "cd frontend && npm run build",
    "test": "NODE_ENV=test jest --coverage",
    "test:auth": "node backend/tests/test-auth-login-error.js",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:load": "k6 run tests/load/scenarios.js",
    "lint": "eslint backend/src frontend/src",
    "lint:fix": "eslint backend/src frontend/src --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "migrate": "node backend/src/db/migrate.js",
    "seed": "node backend/src/db/seed.js",
    "deploy:starter": "cd infrastructure/terraform/environments/starter && terraform apply",
    "deploy:production": "cd infrastructure/terraform/environments/production && terraform apply",
    "docker:build": "docker build -t wazassist-backend -f infrastructure/docker/Dockerfile.backend .",
    "docker:run": "docker-compose -f infrastructure/docker/docker-compose.yml up",
    "docs:generate": "node scripts/generate-docs.js"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.470.0",
    "@aws-sdk/client-s3": "^3.470.0",
    "@aws-sdk/client-secrets-manager": "^3.470.0",
    "@aws-sdk/client-sns": "^3.470.0",
    "@aws-sdk/client-sqs": "^3.470.0",
    "@aws-sdk/s3-request-presigner": "^3.958.0",
    "@langchain/community": "^0.0.40",
    "@langchain/core": "^0.1.30",
    "axios": "^1.6.5",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.1.20",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "multer-s3": "^3.0.1",
    "openai": "^6.15.0",
    "pdfkit": "^0.14.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-cloudwatch": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/wazassist-ai.git"
  },
  "keywords": [
    "whatsapp",
    "ai",
    "chatbot",
    "business",
    "nigeria",
    "aws",
    "bedrock",
    "llama"
  ],
  "author": "WazAssist Team",
  "license": "PROPRIETARY"
}
